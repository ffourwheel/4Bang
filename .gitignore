# ============================================================
#  .gitignore — Modo App (Next.js + Python Data Pipeline)
# ============================================================

# --------------------------------------------------------
#  Dependencies
# --------------------------------------------------------
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --------------------------------------------------------
#  Next.js Build Output
# --------------------------------------------------------
/.next/
/out/

# --------------------------------------------------------
#  Production Build
# --------------------------------------------------------
/build
/dist

# --------------------------------------------------------
#  Environment Variables
#  (อาจมีข้อมูลลับ — ห้าม commit)
# --------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# --------------------------------------------------------
#  Vercel
# --------------------------------------------------------
.vercel

# --------------------------------------------------------
#  TypeScript
# --------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# --------------------------------------------------------
#  Debug & Log Files
# --------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# --------------------------------------------------------
#  Testing & Coverage
# --------------------------------------------------------
/coverage
*.lcov
.nyc_output

# --------------------------------------------------------
#  IDE / Editor Settings
# --------------------------------------------------------

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace

# JetBrains (WebStorm, IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# --------------------------------------------------------
#  OS Generated Files
# --------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*.directory

# --------------------------------------------------------
#  Python (Data Pipeline)
# --------------------------------------------------------

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
ENV/
env/
.conda/

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
*.whl

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Python misc
*.pyo
*.pdb
pip-log.txt
pip-delete-this-directory.txt

# --------------------------------------------------------
#  Machine Learning / Model Files
# --------------------------------------------------------
*.pkl
*.joblib
*.h5
*.hdf5
*.onnx
*.pt
*.pth
*.pb
*.tflite
*.mlmodel
*.caffemodel

# Large dataset files (ถ้าไม่ต้องการ track)
# *.csv
# *.xlsx

# Weights & Biases
wandb/

# MLflow
mlruns/

# --------------------------------------------------------
#  Security & Credentials
# --------------------------------------------------------
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
id_rsa
id_dsa
*.env

# --------------------------------------------------------
#  Misc
# --------------------------------------------------------

# Storybook
storybook-static/

# ESLint cache
.eslintcache

# Prettier cache
.prettiercache

# Stylelint cache
.stylelintcache

# Turbo
.turbo

# PWA
**/public/sw.js
**/public/workbox-*.js
**/public/swe-worker-*.js

# Docker
docker-compose.override.yml

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup
*.old

# Zip / Archive
*.zip
*.tar.gz
*.rar
*.7z
