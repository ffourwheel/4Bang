# ============================================================
#  .gitignore — 4Bangs Project (Next.js + Python FastAPI/ML)
# ============================================================

# --------------------------------------------------------
#  Node.js / React / Next.js (Frontend)
# --------------------------------------------------------
node_modules/
modo-app/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
.next/
modo-app/.next/
out/
build/
dist/
modo-app/out/
modo-app/build/

# Node logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --------------------------------------------------------
#  Python / FastAPI / Data Science (Backend & Models)
# --------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Virtual Environments
venv/
env/
.venv/
.env/
ENV/
env.bak/
venv.bak/

# Jupyter Notebooks
.ipynb_checkpoints/

# (หมายเหตุ: ไม่ได้ ignore *.pkl เผื่อคุณต้องการ push โมเดล dt.pkl ขึ้น git)

# --------------------------------------------------------
#  Environment Variables (Secrets)
# --------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# --------------------------------------------------------
#  IDE / OS Files
# --------------------------------------------------------
.vscode/
.idea/
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db